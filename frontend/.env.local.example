# このファイルを frontend/.env.local にコピーして API キーを設定してください。
# cp .env.local.example .env.local
#
# 注意: frontend/api/.env.local ではなく frontend/.env.local に置いてください。

# ローカル開発: Vite dev サーバーの /api/ocr-shogi で使用（推奨）
GEMINI_API_KEY=

# ローカル開発: ブラウザから直接 Gemini API を呼ぶ場合（任意）
# VITE_GEMINI_API_KEY=your_gemini_api_key_here

# 本番（Vercel）では Vercel の Environment Variables に
# GEMINI_API_KEY を設定してください。
